{
  "name": "chiper-api",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "npm run build:logistica && npm run build:inventario && npm run build:ventas",
    "build:logistica": "nest build logistica",
    "build:inventario": "nest build inventario",
    "build:ventas": "nest build ventas",
    "db:seed": "ts-node -r tsconfig-paths/register scripts/seed-database.ts",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\" \"test/**/*.ts\" \"scripts/**/*.ts\"",
    "start": "npm run start:logistica",
    "start:dev": "npm run start:logistica:dev",
    "start:debug": "nest start logistica --debug --watch",
    "start:logistica": "nest start logistica",
    "start:logistica:dev": "nest start logistica --watch",
    "start:logistica:prod": "node dist/apps/logistica/main",
    "start:inventario": "nest start inventario",
    "start:inventario:dev": "nest start inventario --watch",
    "start:inventario:prod": "node dist/apps/inventario/main",
    "start:ventas": "nest start ventas",
    "start:ventas:dev": "nest start ventas --watch",
    "start:ventas:prod": "node dist/apps/ventas/main",
    "start:prod": "npm run start:logistica:prod",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "npm run test:e2e:logistica && npm run test:e2e:inventario && npm run test:e2e:ventas",
    "test:e2e:logistica": "jest --config ./test/jest-logistica-e2e.json --runInBand",
    "test:e2e:inventario": "jest --config ./test/jest-inventario-e2e.json --runInBand",
    "test:e2e:ventas": "jest --config ./test/jest-ventas-e2e.json --runInBand"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/typeorm": "^11.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "js-yaml": "^4.1.1",
    "pg": "^8.13.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.28",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.7",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "coverage",
    "testEnvironment": "node"
  }
}
